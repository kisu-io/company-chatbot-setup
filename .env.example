# ~/.hermes/.env — Environment Variables

# Wiki Configuration
WIKI_PATH=~/projects/company-chatbot/company-wiki

# Lark/Feishu API Credentials
LARK_APP_ID=cli_xxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxx
LARK_TENANT_KEY=xxxxxxxxx

# Optional: For MCP bridge approach
LARK_MCP_URL=https://your-mcp-server.com/lark

# Telegram (already configured, but for reference)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Model Configuration (override if needed)
HERMES_MODEL=qwen3.5:397b
HERMES_PROVIDER=ollama-cloud
